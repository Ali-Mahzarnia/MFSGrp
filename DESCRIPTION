Package: MFSGrp
Type: Package
Title: Computes multivariate Scalar-on-Functional Elastic Net solution
        path in serial and parallel
Version: 1.0.0
Date: 2021-03-22
Authors@R: c(
  person("Ali", "Mahzarnia", email = "amahzarn@uncc.edu",
  role = c("aut", "cre"), comment = "https://math.uncc.edu/directory/ali-mahzarnia"),
